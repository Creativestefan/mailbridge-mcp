# Provider: Yahoo Mail
# Auth: Yahoo email + App Password from Yahoo Account Security settings

IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@yahoo.com
IMAP_PASSWORD=your_app_password_here

SMTP_HOST=smtp.mail.yahoo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yahoo.com
SMTP_PASSWORD=your_app_password_here
