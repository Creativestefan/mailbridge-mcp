# Provider: Microsoft Outlook / Hotmail / Live
# Auth: Microsoft account email + password (or App Password if 2FA enabled)

IMAP_HOST=outlook.office365.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@outlook.com
IMAP_PASSWORD=your_password_here

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@outlook.com
SMTP_PASSWORD=your_password_here
