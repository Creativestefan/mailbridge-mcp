# Provider: Gmail (Google Workspace / Personal)
# Auth: Gmail address + App Password (requires 2FA enabled)
# Enable IMAP: Gmail Settings → See All Settings → Forwarding and POP/IMAP
# Generate App Password: myaccount.google.com → Security → 2-Step Verification → App passwords

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your_app_password_here

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here
