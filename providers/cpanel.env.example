# Provider: cPanel / Personal Domain Email
# Hosts: Namecheap, HostGator, Bluehost, SiteGround, GoDaddy, etc.
# Auth: your email address + cPanel email password

IMAP_HOST=mail.yourdomain.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=you@yourdomain.com
IMAP_PASSWORD=your_email_password

SMTP_HOST=mail.yourdomain.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@yourdomain.com
SMTP_PASSWORD=your_email_password
